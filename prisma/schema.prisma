generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id
  timezone       String         @default("Africa/Algiers")
  caregiverToken String?        @unique
  wrapData       Json?
  createdAt      DateTime       @default(now())
  checkins       Checkin[]
  episodes       Episode[]
  warnings       Warning[]
  substances     SubstanceLog[]
  medications    Medication[]
}

model Checkin {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  date         DateTime @db.Date
  mood         Int
  energy       Int
  sleep        Float
  medsTaken    Boolean
  word         String
  note         String?
  aiReflection String?
  createdAt    DateTime @default(now())

  @@unique([userId, date])
}

model Episode {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  type       String
  startDate  DateTime
  endDate    DateTime?
  trigger    String?
  whatHelped String?
  severity   Int
  notes      String?
  createdAt  DateTime  @default(now())
}

model Warning {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  description String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model SubstanceLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  substance String
  date      DateTime
  amount    String?
  notes     String?
  createdAt DateTime @default(now())
}

model Medication {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  dosage    String?
  frequency String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
